# vps/Dockerfile.gateway — OmniAgent Gateway 容器
FROM node:22-alpine

WORKDIR /app

# 安裝依賴
COPY vps/package.json ./
RUN npm install

# 複製源代碼
COPY vps/omni-server.mjs ./
COPY vps/omni-server-secure.mjs ./
COPY vps/ecosystem.esggo.config.cjs ./

# 暴露端口
EXPOSE 8642

# 健康檢查
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8642/status || exit 1

# 啟動
CMD ["node", "omni-server.mjs"]
