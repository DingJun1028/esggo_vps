# ESGGO VPS Cron Jobs
# Install with: crontab configs/cron-esggo

# Health check every 5 minutes
*/5 * * * * /var/www/esggo/vps/configs/health-check.sh >> /var/log/esggo-health.log 2>&1

# Daily backup at 03:00
0 3 * * * /var/www/esggo/vps/backup.sh --cron >> /var/log/esggo-backup.log 2>&1

# Weekly full backup on Sunday
0 3 * * 0 /var/www/esggo/vps/backup.sh --cron --weekly >> /var/log/esggo-backup.log 2>&1

# Monthly cold backup on 1st
0 3 1 * * /var/www/esggo/vps/backup.sh --cron --monthly >> /var/log/esggo-backup.log 2>&1

# Logrotate (already handled by logrotate.d, but keep as safety)
0 4 * * * /usr/sbin/logrotate /etc/logrotate.d/esggo
