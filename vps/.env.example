# =============================================================================
# ESGGO VPS Docker Deployment — Required Environment Variables
# Copy this file to .env and fill in your values before running docker-compose
# =============================================================================

# ─── AI Provider Keys (all free tiers) ─────────────────────────
# Groq: 30 req/min, no daily cap — fastest free inference
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter: 200 req/day free tier — widest model selection
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Gemini: free tier available
# NOTE: real values live in .env.secrets (gitignored) — never commit live keys here.
GEMINI_API_KEY=your-gemini-api-key
AGNES_API=your-agnes-api-key
NEXT_PUBLIC_AGNES_API_KEY=your-agnes-api-key

# ─── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Redis (defaults work with docker-compose redis service) ───
# REDIS_HOST=redis
# REDIS_PORT=6379
